PREHOOK: query: EXPLAIN VECTORIZATION DETAIL
SELECT dept, region, emp_id,
  SUM(salary) OVER (
    PARTITION BY dept, region
    ORDER BY dept
    ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) AS total
FROM t1
