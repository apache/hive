PREHOOK: query: INSERT INTO TABLE repro_batch_test PARTITION (part_key)
SELECT
    val as id,
    'dummy_data' as name,
    val as part_key
FROM (
    SELECT (a.pos + 1) as val
    FROM (SELECT posexplode(split(repeat(',', 10), ','))) a
) dummy
